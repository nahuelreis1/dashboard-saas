---
return Astro.redirect("/");
import DashboardLayout from '../layouts/DashboardLayout.astro';
import FileUploader from '../components/FileUploader';
import DriveFolderSelector from '../components/DriveFolderSelector';
---

<DashboardLayout title="Base de Conocimiento">
  <div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
    <div class="flex flex-col gap-2">
      <h2 class="text-3xl font-bold tracking-tight">Base de Conocimiento</h2>
      <p class="text-[var(--muted-foreground)] text-lg">
        Carga la documentación de tu empresa para que la IA pueda responder consultas específicas de tus clientes.
      </p>
    </div>

    <div class="grid gap-8">
      <div>
        <DriveFolderSelector client:load />

        <div class="bg-[var(--card)] border border-[var(--border)] rounded-2xl p-8 shadow-sm">
          <h3 class="text-xl font-semibold mb-6 flex items-center gap-2">
            Subir Documentos
          </h3>
          <FileUploader client:load />
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl bg-blue-500/5 border border-blue-500/10 space-y-3">
          <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-600 dark:text-blue-400 font-bold">1</div>
          <h4 class="font-semibold text-slate-900 dark:text-slate-100">Carga tus archivos</h4>
          <p class="text-sm text-[var(--muted-foreground)]">Sube manuales, FAQs o catálogos en PDF, DOCX o TXT.</p>
        </div>
        <div class="p-6 rounded-2xl bg-purple-500/5 border border-purple-500/10 space-y-3">
          <div class="w-10 h-10 rounded-lg bg-purple-500/20 flex items-center justify-center text-purple-600 dark:text-purple-400 font-bold">2</div>
          <h4 class="font-semibold text-slate-900 dark:text-slate-100">Vectorización Automática</h4>
          <p class="text-sm text-[var(--muted-foreground)]">Nuestra IA fragmenta y procesa la información en segundos.</p>
        </div>
        <div class="p-6 rounded-2xl bg-emerald-500/5 border border-emerald-500/10 space-y-3">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400 font-bold">3</div>
          <h4 class="font-semibold text-slate-900 dark:text-slate-100">IA Lista para Responder</h4>
          <p class="text-sm text-[var(--muted-foreground)]">Tus agentes automáticos ya pueden usar este nuevo conocimiento.</p>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
