---
// src/pages/dashboard.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Panel General">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col">
      <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Conversaciones</span>
      <span class="text-3xl font-bold text-slate-900">1,284</span>
      <div class="mt-4 text-xs font-semibold text-green-600 bg-green-50 self-start px-2 py-1 rounded">+12% vs ayer</div>
    </div>
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col">
      <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Tokens Usados</span>
      <span class="text-3xl font-bold text-slate-900">45.2k</span>
      <div class="mt-4 text-xs font-semibold text-slate-500 bg-slate-100 self-start px-2 py-1 rounded">Dentro de límites</div>
    </div>
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col">
      <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Costo Estimado</span>
      <span class="text-3xl font-bold text-slate-900">$12.45</span>
      <div class="mt-4 text-xs font-semibold text-blue-600 bg-blue-50 self-start px-2 py-1 rounded">Basado en uso real</div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-6 border-b border-slate-100">
      <h3 class="text-lg font-bold text-slate-900">Agentes Activos</h3>
    </div>
    <div class="p-12 text-center">
      <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
         <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      </div>
      <p class="text-slate-500 font-medium">Aún no has creado agentes personalizados.</p>
      <a href="/config" class="mt-6 inline-block bg-blue-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-blue-700 transition-colors">Crear primer Agente</a>
    </div>
  </div>
</DashboardLayout>
